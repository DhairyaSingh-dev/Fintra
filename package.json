{
  "name": "fintra",
  "version": "1.0.0",
  "description": "Fintra - Quantitative trading platform",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom=static/**/*.js"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": ["js"],
    "testMatch": ["**/__tests__/**/*.test.js"],
    "setupFilesAfterEnv": [],
    "transform": {},
    "collectCoverageFrom": [
      "static/**/*.js",
      "!static/__tests__/**"
    ]
  }
}
